# ── HG Growth Lab — Variables de entorno ──────────────────
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio.

# Clave de Web3Forms para el envío del formulario de contacto.
# Obtén la tuya en: https://web3forms.com
WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Puerto en que escucha el servidor (EasyPanel lo inyecta automáticamente).
# Valor por defecto si no se define: 3000
PORT=3000
